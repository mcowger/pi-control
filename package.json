{
	"name": "@mcowger/pi-control",
	"version": "0.3.2",
	"description": "Action-based filesystem policies for pi tool calls.",
	"repository": {
		"type": "git",
		"url": "https://github.com/mcowger/pi-control.git"
	},
	"type": "module",
	"keywords": [
		"pi-package"
	],
	"files": [
		"src",
		"skills",
		"examples",
		"README.md"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"test": "bun test",
		"check": "biome check .",
		"format": "biome format --write ."
	},
	"pi": {
		"extensions": [
			"./src/index.ts"
		],
		"skills": [
			"./skills"
		]
	},
	"dependencies": {
		"@vscode/tree-sitter-wasm": "^0.3.1",
		"minimatch": "^10.2.5",
		"strip-json-comments": "^5.0.3"
	},
	"peerDependenciesMeta": {
		"@earendil-works/pi-coding-agent": {
			"optional": true
		}
	},
	"devDependencies": {
		"@earendil-works/pi-coding-agent": "^0.80.2",
		"@types/bun": "^1.3.14",
		"@biomejs/biome": "^2.5.1",
		"typescript": "^6.0.3"
	}
}
